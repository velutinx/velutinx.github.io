<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>[Pack 001] Tsunade - Naruto</title>
  <style>
    :root {
      --bg: #d3d0c1;
      --card: #e8e5d8;
      --darker: #c0bcaa;
      --text: #3a3528;
      --text-light: #8a7b6f;
      --accent: #aa9e76;
      --border: #aa9e76;
      --primary: #5D87FF;
      --danger: #FA896B;
      --radius: 8px;
      --shadow: 0 4px 12px rgba(0,0,0,0.12);
    }

    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
    }

    /* ── Top Navigation ── exact match to store.html sizing & style */
    .top-nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.9rem 2.5rem;
      background: var(--darker);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .logo {
      font-size: 1.8rem;
      font-weight: 900;
      letter-spacing: 2px;
      color: #000;
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .nav-icon {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text);
      border: 1px solid rgba(58,53,40,0.2);
      transition: all 0.22s;
      cursor: pointer;
    }

    .nav-icon:hover {
      background: #d3d0c1;
      color: #3a3528;
      transform: scale(1.08);
      border-color: #aa9e76;
    }

    .login-btn {
      padding: 0.55rem 1.6rem;
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--accent);
      border-radius: 9999px;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      transition: all 0.18s;
    }

    .login-btn:hover {
      background: rgba(170,158,118,0.15);
    }

    /* ── Main Content ── */
    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 16px;
    }

    @media (min-width: 600px) {
      .container { padding: 0 24px; }
    }

    main { padding: 40px 0; }

    .product {
      display: grid;
      gap: 40px;
    }

    @media (min-width: 992px) {
      .product { grid-template-columns: 1fr 2fr; }
    }

    .gallery-card,
    .info-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
    }

    /* ── Sliding Carousel ── */
    .carousel {
      position: relative;
      overflow: hidden;
      height: auto;
    }

    .slides {
      display: flex;
      transition: transform 0.5s ease-in-out;
      width: 100%;
    }

    .slide {
      flex: 0 0 100%;
      width: 100%;
    }

    .slide img {
      width: 100%;
      height: auto;
      display: block;
    }

    .arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: rgba(0,0,0,0.4);
      color: white;
      border: none;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      font-size: 24px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 10;
    }

    .arrow:hover { background: rgba(0,0,0,0.6); }
    .arrow.prev { left: 16px; }
    .arrow.next { right: 16px; }

    .thumbnails {
      display: flex;
      gap: 12px;
      justify-content: center;
      padding: 16px;
      background: rgba(0,0,0,0.03);
      border-top: 1px solid var(--border);
      flex-wrap: wrap;
    }

    .thumb {
      width: 90px;
      height: 120px;
      object-fit: cover;
      border-radius: 6px;
      border: 3px solid transparent;
      cursor: pointer;
      transition: all 0.2s;
      opacity: 0.8;
    }

    .thumb.active,
    .thumb:hover {
      border-color: var(--primary);
      opacity: 1;
      transform: scale(1.04);
    }

    .info {
      padding: 28px;
    }

    h1 {
      font-size: 2.1rem;
      margin-bottom: 20px;
      color: var(--text);
    }

    .price-section {
      margin: 28px 0;
      padding: 20px;
      background: rgba(250,137,107,0.08);
      border-radius: 12px;
      border: 1px solid rgba(250,137,107,0.25);
    }

    .price-label { color: var(--text-light); font-size: 0.95rem; }
    .old-price {
      text-decoration: line-through;
      color: var(--text-light);
      margin-left: 12px;
    }
    .current-price {
      color: var(--danger);
      font-size: 2.2rem;
      font-weight: bold;
    }

    .save {
      color: #13DEB9;
      font-weight: bold;
      margin-top: 8px;
      display: inline-block;
    }

    .buttons {
      display: flex;
      gap: 16px;
      margin-top: 32px;
      flex-wrap: wrap;
    }

    .btn {
      flex: 1;
      min-width: 160px;
      padding: 14px 24px;
      border: none;
      border-radius: var(--radius);
      font-size: 1.1rem;
      font-weight: 500;
      cursor: pointer;
      transition: 0.2s;
    }

    .btn-buy {
      background: var(--primary);
      color: white;
    }
    .btn-buy:hover { background: #4570ea; }

    .btn-cart {
      background: #49BEFF;
      color: white;
    }
    .btn-cart:hover { background: #23afdb; }

    .note,
    .disclaimer {
      margin-top: 24px;
      font-size: 0.95rem;
      color: #555;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .disclaimer {
      margin-top: 32px;
      padding-top: 20px;
      border-top: 1px solid var(--border);
    }

    .note svg,
    .disclaimer svg {
      flex-shrink: 0;
      width: 20px;
      height: 20px;
    }
  </style>
</head>
<body>

  <!-- Top Navigation ── identical sizing/layout to store.html -->
  <nav class="top-nav">
    <div class="logo">VELUTINX</div>
    <div class="nav-actions">
      <button class="login-btn">Website</button>

      <button class="nav-icon" title="Language">
        <svg xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 5h7"></path>
          <path d="M7 4c0 4.846 0 7 .5 8"></path>
          <path d="M10 8.5c0 2.286 -2 4.5 -3.5 4.5s-2.5 -1.135 -2.5 -2c0 -2 1 -3 3 -3s5 .57 5 2.857c0 1.524 -.667 2.571 -2 3.143"></path>
          <path d="M12 20l4 -9l4 9"></path>
          <path d="M19.1 18h-6.2"></path>
        </svg>
      </button>

      <button class="nav-icon" title="Night Mode">
        <svg xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 12m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0"></path>
          <path d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7"></path>
        </svg>
      </button>

      <div class="cart-wrapper">
        <button class="nav-icon" title="Cart">
          <svg xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M6 19m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"></path>
            <path d="M17 19m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"></path>
            <path d="M17 17h-11v-14h-2"></path>
            <path d="M6 5l14 1l-.86 6.017m-2.64 .983h-10.5"></path>
          </svg>
        </button>
        <span class="cart-badge">0</span>
      </div>
    </div>
  </nav>

  <main class="container">
    <div class="product">

      <!-- Gallery with slide animation -->
      <div class="gallery-card">
        <div class="carousel">
          <div class="slides" id="slides">
            <div class="slide"><img src="https://velutinx.neocities.org/Images/Artwork/1.jpg" alt="1"></div>
            <div class="slide"><img src="https://velutinx.neocities.org/Images/Artwork/2.jpg" alt="2"></div>
            <div class="slide"><img src="https://velutinx.neocities.org/Images/Artwork/3.jpg" alt="3"></div>
            <div class="slide"><img src="https://velutinx.neocities.org/Images/Artwork/4.jpg" alt="4"></div>
          </div>

          <button class="arrow prev" onclick="prevSlide()">❮</button>
          <button class="arrow next" onclick="nextSlide()">❯</button>
        </div>

        <div class="thumbnails">
          <img class="thumb active" src="https://velutinx.neocities.org/Images/Artwork/1.jpg" onclick="goToSlide(0)" alt="1">
          <img class="thumb" src="https://velutinx.neocities.org/Images/Artwork/2.jpg" onclick="goToSlide(1)" alt="2">
          <img class="thumb" src="https://velutinx.neocities.org/Images/Artwork/3.jpg" onclick="goToSlide(2)" alt="3">
          <img class="thumb" src="https://velutinx.neocities.org/Images/Artwork/4.jpg" onclick="goToSlide(3)" alt="4">
        </div>
      </div>

      <!-- Info -->
      <div class="info-card">
        <div class="info">
          <h1>[Pack 001] Tsunade - Naruto</h1>

          <div class="price-section">
            <div>
              <span class="price-label">Original Price:</span>
              <span class="old-price">US$5.79</span>
            </div>
            <div style="margin-top:8px;">
              <span class="price-label">Current Price:</span>
              <span class="current-price">US$4.49</span>
            </div>
            <div class="save">Save US$1.30 (23% OFF)</div>
          </div>

          <div class="buttons">
            <button class="btn btn-buy">Buy Now</button>
            <button class="btn btn-cart">Add to Cart</button>
          </div>

          <div class="note">
            <svg width="512" height="512" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
              <path d="M256 40 L472 440 H40 Z" fill="#FFC107" stroke="#000000" stroke-width="32" stroke-linejoin="round"/>
              <rect x="236" y="180" width="40" height="160" rx="20" fill="#000000"/>
              <circle cx="256" cy="380" r="24" fill="#000000"/>
            </svg>
            Digital products are non-refundable after purchase.
          </div>

          <div class="disclaimer">
            <svg width="512" height="512" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
              <path d="M256 40 L472 440 H40 Z" fill="#FFC107" stroke="#000000" stroke-width="32" stroke-linejoin="round"/>
              <rect x="236" y="180" width="40" height="160" rx="20" fill="#000000"/>
              <circle cx="256" cy="380" r="24" fill="#000000"/>
            </svg>
            <span>Disclaimer: All characters depicted are portrayed as 18+. This is a fictional, consensual depiction.</span>
          </div>
        </div>
      </div>

    </div>
  </main>

  <script>
    const slidesContainer = document.getElementById('slides');
    const thumbs = document.querySelectorAll('.thumb');
    let current = 0;
    const total = 4;

    function update() {
      // Slide the container
      slidesContainer.style.transform = `translateX(-${current * 100}%)`;

      // Update thumbnails
      thumbs.forEach((t, i) => t.classList.toggle('active', i === current));
    }

    function nextSlide() {
      current = (current + 1) % total;
      update();
    }

    function prevSlide() {
      current = (current - 1 + total) % total;
      update();
    }

    function goToSlide(index) {
      current = index;
      update();
    }

    // Init
    update();
  </script>

</body>
</html>
